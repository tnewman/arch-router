#!/usr/bin/env python3

import json
from vpp_papi import VPPApiClient 

vpp = VPPApiClient()
vpp.connect('vpp')

interfaces = [interface.interface_name for interface in vpp.api.sw_interface_dump() if 'dpdk' == interface.interface_dev_type]

vpp.disconnect()

vpp_facts = {
    'wan_interface': interfaces[0] if len(interfaces) > 0 else None,
    'lan_interfaces': [interface for interface in interfaces[1:]],
}

print(json.dumps(vpp_facts))
