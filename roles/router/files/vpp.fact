#!/usr/bin/env python3

import json
from vpp_papi import VPPApiClient 

vpp = VPPApiClient()
vpp.connect('vpp')

interfaces = [interface.interface_name for interface in vpp.api.sw_interface_dump() if 'dpdk' == interface.interface_dev_type]

vpp.disconnect()

vpp_facts = {
    'ethernet_interfaces': []
}

for interface in interfaces:
    vpp_facts['ethernet_interfaces'].append(interface)

print(json.dumps(vpp_facts))
