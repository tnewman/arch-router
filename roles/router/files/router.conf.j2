set dhcp client intfc GigabitEthernet1/0/0
set interface state GigabitEthernet1/0/0 up

bvi create instance 0
set interface l2 bridge bvi0 1 bvi
set interface ip address bvi0 10.0.0.1/24
set interface state bvi0 up

create tap id 0 host-ip4-addr 10.0.0.2/24 host-ip4-gw 10.0.0.1
set interface l2 bridge tap0 1
set interface state tap0 up

nat44 enable
nat44 add interface address GigabitEthernet1/0/0
set interface nat44 in bvi0 out GigabitEthernet1/0/0

nat44 add static mapping tcp local 10.0.0.2 22 external GigabitEthernet1/0/0 22
