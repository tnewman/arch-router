set dhcp client intfc {{ ansible_facts['ansible_local']['vpp']['wan_interface'] }}
set interface state {{ ansible_facts['ansible_local']['vpp']['wan_interface'] }} up

bvi create instance 0
set interface l2 bridge bvi0 1 bvi
set interface ip address bvi0 10.0.0.1/24
set interface state bvi0 up

create tap id 0 host-ip4-addr 10.0.0.2/24 host-ip4-gw 10.0.0.1
set interface l2 bridge tap0 1
set interface state tap0 up

nat44 enable
nat44 add interface address {{ ansible_facts['ansible_local']['vpp']['wan_interface'] }}
set interface nat44 in bvi0 out {{ ansible_facts['ansible_local']['vpp']['wan_interface'] }}

nat44 add static mapping tcp local 10.0.0.2 22 external {{ ansible_facts['ansible_local']['vpp']['wan_interface'] }} 22
